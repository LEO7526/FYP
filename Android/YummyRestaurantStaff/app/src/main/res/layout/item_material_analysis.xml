<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="#DCEBFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Material Name + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textMaterialName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
android:text="@string/ingredient_name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/textStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="OK"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Current Qty -->
        <TextView
            android:id="@+id/textCurrentQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/current_units_placeholder"
            android:textSize="13sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="8dp" />

        <!-- Average Weekly Usage -->
        <TextView
            android:id="@+id/textAvgUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/avg_weekly_placeholder"
            android:textSize="13sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp" />

        <!-- Restock Point -->
        <TextView
            android:id="@+id/textRestockPoint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/restock_point_placeholder"
            android:textSize="13sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnRestockItem"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:text="@string/restock_now"
            android:textAllCaps="false"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@android:color/white"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
