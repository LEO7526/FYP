<com.google.android.material.card.MaterialCardView
    android:id="@+id/menuItemCardView"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:rippleColor="@color/orange_light"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/card_border_normal">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Dish Image -->
        <FrameLayout
            android:id="@+id/dishImageContainer"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/image_rounded_bg"
            android:backgroundTint="#F5F5F5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            
            <ImageView
                android:id="@+id/dishImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/menu_item_image_desc" />
        </FrameLayout>

        <!-- Dish Name -->
        <TextView
            android:id="@+id/dishName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/dish_name_placeholder"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/dishImageContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Dish Description (Hidden) -->
        <TextView
            android:id="@+id/dishDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/dish_description_placeholder"
            android:textSize="14sp"
            android:textColor="#666666"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/dishName"
            app:layout_constraintTop_toBottomOf="@id/dishName"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Dish Price -->
        <TextView
            android:id="@+id/dishPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dish_price_placeholder"
            android:textSize="14sp"
            android:textColor="#FF5722"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toStartOf="@id/dishName"
            app:layout_constraintTop_toBottomOf="@id/dishName"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed" />

        <!-- Spice Level Bar -->
        <LinearLayout
            android:id="@+id/spiceIconContainer"
            android:layout_width="wrap_content"
            android:layout_height="12dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/dishPrice"
            app:layout_constraintTop_toTopOf="@id/dishPrice"
            app:layout_constraintBottom_toBottomOf="@id/dishPrice"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>