<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Trust system certificates and use default trust anchors -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">raw.githubusercontent.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Allow cleartext traffic for local development APIs (XAMPP) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.0.122</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>

    <!-- Default configuration - secure HTTPS only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>