<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_kitchen_screen_surface">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_kitchen_header_premium"
            android:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:id="@+id/hamburger_menu"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/menu"
                        android:src="@drawable/ic_menu"
                        app:tint="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="@string/staff_orders_header"
                        android:textAppearance="@style/StaffToolbarTitle"
                        android:textColor="@color/white" />

                    <ImageView
                        android:id="@+id/staffSettingsIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/white" />
                </RelativeLayout>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/orderTabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/order_tabs_navigation"
                    android:padding="6dp"
                    android:background="@drawable/bg_kitchen_tabs_shell"
                    app:tabMode="fixed"
                    app:tabGravity="fill"
                    app:tabMinWidth="0dp"
                    app:tabPaddingStart="0dp"
                    app:tabPaddingEnd="0dp"
                    app:tabIndicatorColor="@android:color/transparent"
                    app:tabIndicatorHeight="0dp"
                    app:tabBackground="@drawable/bg_kitchen_tab_item"
                    app:tabRippleColor="#66E3F2FD"
                    app:tabTextAppearance="@style/StaffTabText"
                    app:tabTextColor="@color/kitchen_tab_text">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_new" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_making" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_delivered" />
                </com.google.android.material.tabs.TabLayout>
            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="10dp"
            android:paddingTop="18dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ordersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvEmptyOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_orders_in_this_tab"
                    android:textColor="@color/dark_gray"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRefreshOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/bg_order_primary_button"
                    android:backgroundTint="@null"
                    app:backgroundTint="@null"
                    android:minWidth="160dp"
                    android:paddingHorizontal="28dp"
                    android:text="@string/refresh"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="312dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:layout_marginEnd="52dp"
        android:background="@drawable/bg_staff_drawer_surface"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_staff"
        app:itemBackground="@drawable/staff_drawer_item_background"
        app:itemHorizontalPadding="16dp"
        app:itemIconPadding="12dp"
        app:itemIconTint="@color/staff_drawer_item_icon"
        app:itemTextAppearance="@style/StaffDrawerItemText"
        app:itemTextColor="@color/staff_drawer_item_text"
        app:itemVerticalPadding="2dp"
        app:menu="@menu/staff_drawer_menu"
        app:subheaderColor="@color/staff_drawer_subheader_text" />

</androidx.drawerlayout.widget.DrawerLayout>