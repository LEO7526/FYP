<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/table_card_background"
    android:padding="12dp"
    android:layout_margin="8dp">

    <!-- Table Number -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/textTableNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Table #5"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/status_pending"
            android:background="#FFE0B2"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <!-- Customer Name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="Customer:"
            android:textSize="13sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/textCustomerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Alex Wong"
            android:textSize="13sp"
            android:textColor="#333" />
    </LinearLayout>

    <!-- Time Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="Time:"
            android:textSize="13sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/textBookingTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="18:30"
            android:textSize="13sp"
            android:textColor="#333" />

        <TextView
            android:id="@+id/textPeople"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4 people"
            android:textSize="13sp"
            android:textColor="#333" />
    </LinearLayout>

</LinearLayout>
